 11:/* *************************************************************** */
 12:/* System 19-9 TMP90C841A SBC decorder Glue logic                  */
 13:/*                                                                 */
 14:/* *************************************************************** */
 15:/* target device        GAL22V10 any speed rank is OK              */
 16:/* *************************************************************** */
 17:/* Memory Map                                                      */
 18:/*  0x0000-0x3fff       ROM (NIBL and extension)                   */
 19:/*  0x4000-0xadff       RAM                                        */
 20:/*  0xfc00-0xfc3f       Serial Interface                           */
 21:/*  0xfc40-0xfcff       I/O area                                   */
 22:/*  0xfd00-0xfdff       reserved                                   */
 23:/*  0xfe00-0xffff       RAM (ffc0-ffff internal)                   */
 24:/* *************************************************************** */
 25:/** inputs      **/
 26:Pin 1   =       OSC;
 27:Pin 2   =       !NRD;
 28:Pin 3   =       !NWR;
 29:Pin 4   =       A15;
 30:Pin 5   =       A14;
 31:Pin 6  =        A7;
 32:Pin 7   =       A6;
 33:Pin 8   =       A5;
 34:Pin 9   =       A4;
 35:Pin 10  =       A3;
 36:Pin 11  =       A2;
 37:Pin 13  =       SPR;
 38:
 39:/** outputs     **/
 40:Pin 14  =       !SEREN;
 41:Pin 15  =       !ROMEN; 
 42:Pin 16  =       !RAMEN;
 43:Pin 17  =       CLKG; 
 44:Pin 18  =       CLKF;
 45:Pin 19  =       CLKE; 
 46:Pin 20  =       CLKD; 
 47:Pin 21  =       CLKC; 
 48:Pin 22  =       CLKB;
 49:Pin 23  =       CLKA;
 50:
 51:/* logic equations      */
 52:CLKA.d  =       !CLKA & (!CLKB # !CLKC # !CLKD);
 53:CLKB.d  =       (!CLKA &  CLKB & !CLKC) #

