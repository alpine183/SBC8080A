 54:                (!CLKA &  CLKB &         !CLKD) #
 55:                ( CLKA & !CLKB);
 56:CLKC.d  =       (!CLKA &          CLKC & !CLKD) #
 57:                (        !CLKB &  CLKC) #
 58:                ( CLKA &  CLKB & !CLKC);
 59:CLKD.d  =       (        !CLKB &          CLKD) #
 60:                (                !CLKC &  CLKD) #
 61:                ( CLKA &  CLKB &  CLKC & !CLKD);
 62:CLKE.d  =       (        !CLKB &                  CLKE) #
 63:                (                !CLKC &          CLKE) #
 64:                (                        !CLKD &  CLKE) #
 65:                (         CLKB &  CLKC &  CLKD & !CLKE);
 66:CLKF.d  =       (        !CLKB &                          CLKF) #
 67:                (                !CLKC &                  CLKF) #
 68:                (                        !CLKD &          CLKF) #
 69:                (                                !CLKE &  CLKF) #
 70:                (         CLKB &  CLKC &  CLKD &  CLKE & !CLKF);
 71:CLKG.d  =       (        !CLKB &                                  CLKG) #
 72:                (                !CLKC &                          CLKG) #
 73:                (                        !CLKD &                  CLKG) #
 74:                (                                !CLKE &          CLKG) #
 75:                (                                        !CLKF &  CLKG) #
 76:                (         CLKB &  CLKC &  CLKD & CLKE  &  CLKF & !CLKG);
 77:
 78:ROMEN   = (NRD & !A15 & !A14);
 79:RAMEN   = (NRD # NWR) & A15;
 80:SEREN   = (!A7 & !A6 & !A5 & !A4 & !A3 & !A2 & !SPR);
 81:
 82:ROMEN.oe = 'b'1;
 83:RAMEN.oe = 'b'1;
 84:SEREN.oe = 'b'1;
 85:CLKA.sp = 'b'0;
 86:CLKA.ar = 'b'0;
 87:CLKB.sp = 'b'0;
 88:CLKB.ar = 'b'0;
 89:CLKC.sp = 'b'0;
 90:CLKC.ar = 'b'0;
 91:CLKD.sp = 'b'0;
 92:CLKD.ar = 'b'0;
 93:CLKE.sp = 'b'0;
 94:CLKE.ar = 'b'0;
 95:CLKF.sp = 'b'0;
 96:CLKF.ar = 'b'0;
 97:CLKG.sp = 'b'0;
 98:CLKG.ar = 'b'0;
